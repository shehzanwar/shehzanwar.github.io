---
// src/pages/about.astro
import PageLayout from '../layouts/PageLayout.astro';
import ExperienceList from '../components/sections/ExperienceList.astro';
import SkillsGrid from '../components/sections/SkillsGrid.astro';
import { getCollection } from 'astro:content';
import { buildMeta } from '../lib/seo';

const meta = buildMeta({
  title: 'About — Shehzad Anwar',
  description:
    'Data analyst and software developer. MS Analytics candidate at Georgia Tech, specializing in computational data analysis, machine learning, and system architecture.',
});

const [experienceEntries, skillEntries] = await Promise.all([
  getCollection('experience'),
  getCollection('skills'),
]);

const experience = experienceEntries
  .sort((a, b) => b.data.start.getTime() - a.data.start.getTime());

const skills = skillEntries
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<PageLayout meta={meta}>
  <div class="page-section">
    <!-- Intro -->
    <section class="about-intro" aria-labelledby="about-heading">
      <h1 id="about-heading" class="about-heading">About</h1>
      <p class="about-lead">
        I'm a data analyst and software developer pursuing a Master of Science
        in Analytics (OMSA) at Georgia Tech. My work spans data engineering,
        machine learning, and system architecture — building pipelines and tools
        that turn raw signals into reliable decisions.
      </p>
      <p class="about-body">
        Most recently I interned as a Data Analyst at Trinamix Inc. in San Jose,
        conducting data integrity audits and writing SQL workflows to remediate
        security vulnerabilities across enterprise systems. Before that I worked
        as a freelance developer through Yanbor LLC., leading technical redesigns
        and engineering data processing tools that reduced processing times by 27%.
        Outside of work I build projects at the intersection of geopolitics and
        commodity markets, and I write occasionally about data tooling and
        reproducible analytics.
      </p>
    </section>

    <!-- Experience -->
    <section class="about-section" aria-labelledby="experience-heading">
      <h2 id="experience-heading" class="section-title" style="margin-bottom: 2rem;">
        Experience
      </h2>
      <ExperienceList entries={experience} />
    </section>

    <!-- Skills -->
    <section class="about-section" aria-labelledby="skills-heading">
      <h2 id="skills-heading" class="section-title" style="margin-bottom: 1.5rem;">
        Skills
      </h2>
      <SkillsGrid skills={skills} />
    </section>
  </div>
</PageLayout>

<style>
  .about-intro {
    max-width: 68ch;
    margin-bottom: 5rem;
  }

  .about-heading {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: 1.5rem;
  }

  .about-lead {
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .about-body {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-tertiary);
  }

  .about-section {
    margin-bottom: 5rem;
  }

  .about-section:last-child {
    margin-bottom: 0;
  }
</style>

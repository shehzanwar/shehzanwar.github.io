---
// src/pages/contact.astro
import PageLayout from '../layouts/PageLayout.astro';
import { buildMeta } from '../lib/seo';

const meta = buildMeta({
  title: 'Contact — Shehzad Anwar',
  description:
    'Get in touch with Shehzad Anwar — data scientist and software developer based in San Francisco.',
});
---

<PageLayout meta={meta}>
  <div class="page-section">
    <header class="contact-header">
      <h1 class="contact-title">Get in Touch</h1>
      <p class="contact-lead">
        I'm always open to discussing data science, analytics engineering, and
        interesting projects. The best way to reach me is by email.
      </p>
    </header>

    <div class="contact-links">
      <a href="mailto:shehzanwar@gmail.com" class="contact-item">
        <span class="contact-platform">Email</span>
        <span class="contact-value">shehzanwar@gmail.com</span>
      </a>

      <a
        href="https://github.com/shehzanwar"
        class="contact-item"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="contact-platform">GitHub</span>
        <span class="contact-value">github.com/shehzanwar</span>
      </a>

      <a
        href="https://linkedin.com/in/shehzanwar"
        class="contact-item"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="contact-platform">LinkedIn</span>
        <span class="contact-value">linkedin.com/in/shehzanwar</span>
      </a>
    </div>
  </div>
</PageLayout>

<style>
  .contact-header {
    max-width: 52ch;
    margin-bottom: 3.5rem;
  }

  .contact-title {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: 1rem;
  }

  .contact-lead {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: padding-left var(--duration-base) var(--ease-out-expo);
  }

  .contact-item:hover { padding-left: 0.75rem; }

  .contact-item:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  .contact-platform {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-tertiary);
    width: 7rem;
    flex-shrink: 0;
  }

  .contact-value {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-accent);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .contact-item:hover .contact-value { color: var(--color-accent-hover); }

  @media (max-width: 480px) {
    .contact-item { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
    .contact-platform { width: auto; }
  }
</style>

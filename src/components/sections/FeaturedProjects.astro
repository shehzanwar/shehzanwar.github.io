---
// src/components/sections/FeaturedProjects.astro
import type { CollectionEntry } from 'astro:content';
import BentoGrid from './BentoGrid.astro';
import BentoCard from '../primitives/BentoCard.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;

// Sort: featured by order first, then non-featured by publishedAt
const sorted = [...projects].sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  if (a.data.featured && b.data.featured) return a.data.order - b.data.order;
  return b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
});

// Asymmetric span map: hero(8×2) | tall(4×2) | square(4×1) | default(4×1)
const spanMap = [
  { col: 8, row: 2 },
  { col: 4, row: 2 },
  { col: 4, row: 1 },
];

const statusLabel: Record<string, string> = {
  shipped: 'Shipped',
  'in-progress': 'In progress',
  archived: 'Archived',
};
---

<section>
  <div class="page-section" style="padding-top: 2rem;">
    <header class="section-header">
      <h2 class="section-title">Featured Work</h2>
      <a href="/work" class="section-link">View all work →</a>
    </header>

    <BentoGrid>
      {sorted.map((project, i) => {
        const { col, row } = spanMap[i] ?? { col: 4, row: 1 };
        return (
          <BentoCard
            href={`/work/${project.data.slug}`}
            colSpan={col}
            rowSpan={row}
            label={project.data.title}
          >
            <div class="card-top">
              {project.data.coverIcon && (
                <span class="card-icon">
                  <Icon name={project.data.coverIcon} size={20} />
                </span>
              )}
              <span class={`status-badge status-badge--${project.data.status}`}>
                {statusLabel[project.data.status] ?? project.data.status}
              </span>
            </div>

            <h3 class="card-title">{project.data.title}</h3>
            <p class="card-summary">{project.data.summary}</p>

            <div class="card-stack">
              {project.data.stack.slice(0, 4).map(s => (
                <span class="chip">{s}</span>
              ))}
              {project.data.stack.length > 4 && (
                <span class="chip">+{project.data.stack.length - 4}</span>
              )}
            </div>
          </BentoCard>
        );
      })}
    </BentoGrid>
  </div>
</section>

<style>
  .card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background-color: oklch(0.44 0.14 240 / 0.10);
    border-radius: var(--radius-md);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .card-title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
    line-height: var(--leading-tight);
  }

  .card-summary {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: auto;
    flex-grow: 1;
    padding-bottom: 1rem;
  }

  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: auto;
  }
</style>

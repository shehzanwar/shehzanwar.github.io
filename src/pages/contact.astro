---
// src/pages/contact.astro
import PageLayout from '../layouts/PageLayout.astro';
import { buildMeta } from '../lib/seo';

const meta = buildMeta({
  title: 'Contact — Shehzad Anwar',
  description:
    'Get in touch with Shehzad Anwar — data scientist and software developer based in San Francisco.',
});

const channels = [
  {
    label:  'Email',
    value:  'shehzanwar@gmail.com',
    href:   'mailto:shehzanwar@gmail.com',
    external: false,
  },
  {
    label:  'GitHub',
    value:  'github.com/shehzanwar',
    href:   'https://github.com/shehzanwar',
    external: true,
  },
  {
    label:  'LinkedIn',
    value:  'linkedin.com/in/shehzanwar',
    href:   'https://linkedin.com/in/shehzanwar',
    external: true,
  },
];
---

<PageLayout meta={meta}>
  <div class="page-section">

    <header class="contact-header">
      <p class="page-eyebrow">Contact</p>
      <h1 class="contact-title">Let's Work Together</h1>
      <p class="contact-lead">
        I'm currently exploring new opportunities in data analytics and machine
        learning. Whether you have a specific role in mind, want to collaborate
        on a project, or just want to talk data — I'd love to hear from you.
      </p>
    </header>

    <div class="contact-grid">
      <!-- Channels -->
      <div>
        <p class="group-label">Reach me directly</p>
        <div class="channels">
          {channels.map(({ label, value, href, external }) => (
            <a
              href={href}
              class="channel"
              {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <div class="channel-body">
                <span class="channel-label">{label}</span>
                <span class="channel-value">{value}</span>
              </div>
              <span class="channel-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Availability note -->
      <div class="availability-card">
        <span class="availability-dot"></span>
        <div>
          <p class="avail-title">Open to opportunities</p>
          <p class="avail-body">
            Actively looking for roles in data analytics, machine learning, and
            data engineering — full-time, contract, or research collaborations.
            Based in the San Francisco Bay Area; open to remote.
          </p>
        </div>
      </div>
    </div>

  </div>
</PageLayout>

<style>
  .contact-header {
    margin-bottom: 3.5rem;
    max-width: 56ch;
  }

  .page-eyebrow {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .contact-title {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .contact-lead {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* ── Grid ──────────────────────────────────────────────── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .group-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: 1rem;
  }

  /* ── Contact channels ──────────────────────────────────── */
  .channels {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .channel {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.125rem 1.25rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition:
      border-color     var(--duration-fast) var(--ease-out-expo),
      background-color var(--duration-fast) var(--ease-out-expo),
      transform        var(--duration-fast) var(--ease-out-expo);
  }

  .channel:hover {
    border-color: rgba(192, 193, 255, 0.25);
    background-color: var(--color-surface-elevated);
    transform: translateX(3px);
  }

  .channel-body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .channel-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  .channel-value {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .channel:hover .channel-value { color: var(--color-accent-hover); }

  .channel-arrow {
    font-size: var(--text-lg);
    color: var(--color-text-tertiary);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .channel:hover .channel-arrow { color: var(--color-accent); }

  /* ── Availability card ─────────────────────────────────── */
  .availability-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    background-color: var(--color-surface);
    border: 1px solid rgba(79, 219, 200, 0.2);
    border-radius: var(--radius-md);
    position: relative;
    overflow: hidden;
  }

  .availability-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg,
      transparent, rgba(79, 219, 200, 0.4), transparent);
  }

  .availability-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--color-secondary);
    box-shadow: 0 0 8px var(--color-secondary), 0 0 16px rgba(79,219,200,0.3);
    flex-shrink: 0;
    margin-top: 0.3rem;
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.45; }
  }

  .avail-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-secondary);
    margin-bottom: 0.5rem;
  }

  .avail-body {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .availability-dot { animation: none; }
  }
</style>

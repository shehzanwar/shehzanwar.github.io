---
// src/components/sections/FeaturedProjects.astro
import type { CollectionEntry } from 'astro:content';
import BentoGrid from './BentoGrid.astro';
import BentoCard from '../primitives/BentoCard.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;

const sorted = [...projects].sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  if (a.data.featured && b.data.featured) return a.data.order - b.data.order;
  return b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
});

const total = sorted.length;

// Dynamic span map: hero full-width | equal split | asymmetric
const spanMap =
  total === 1 ? [{ col: 12, row: 2 }] :
  total === 2 ? [{ col: 6, row: 2 }, { col: 6, row: 2 }] :
                [{ col: 8, row: 2 }, { col: 4, row: 2 }, { col: 4, row: 1 }];

const statusLabel: Record<string, string> = {
  shipped: 'Shipped',
  'in-progress': 'In progress',
  archived: 'Archived',
};
---

<section>
  <div class="page-section" style="padding-top: 2rem;">
    <header class="section-header">
      <h2 class="section-title">Featured Work</h2>
      <a href="/projects" class="section-link">View all projects →</a>
    </header>

    <BentoGrid>
      {sorted.map((project, i) => {
        const { col, row } = spanMap[i] ?? { col: 4, row: 1 };
        const isHero = total === 1;
        return (
          <BentoCard
            href={`/projects/${project.data.slug}`}
            colSpan={col}
            rowSpan={row}
            label={project.data.title}
          >
            <div class={isHero ? 'hero-layout' : 'card-layout'}>
              <div class="card-main">
                <div class="card-top">
                  {project.data.coverIcon && (
                    <span class="card-icon" style={isHero ? 'width:2.75rem;height:2.75rem;' : ''}>
                      <Icon name={project.data.coverIcon} size={isHero ? 26 : 20} />
                    </span>
                  )}
                  <span class={`status-badge status-badge--${project.data.status}`}>
                    {statusLabel[project.data.status] ?? project.data.status}
                  </span>
                </div>

                <h3 class={isHero ? 'hero-title' : 'card-title'}>{project.data.title}</h3>
                <p class={isHero ? 'hero-summary' : 'card-summary'}>{project.data.summary}</p>

                {!isHero && (
                  <div class="card-stack">
                    {project.data.stack.slice(0, 4).map(s => (
                      <span class="chip">{s}</span>
                    ))}
                    {project.data.stack.length > 4 && (
                      <span class="chip">+{project.data.stack.length - 4}</span>
                    )}
                  </div>
                )}
              </div>

              {isHero && (
                <div class="hero-aside">
                  <div class="card-stack">
                    {project.data.stack.map(s => (
                      <span class="chip">{s}</span>
                    ))}
                  </div>
                  {project.data.repoUrl && (
                    <span class="hero-cta">View on GitHub →</span>
                  )}
                  {!project.data.repoUrl && (
                    <span class="hero-cta">View project →</span>
                  )}
                </div>
              )}
            </div>
          </BentoCard>
        );
      })}
    </BentoGrid>
  </div>
</section>

<style>
  /* ── Shared card layout ──────────────────── */
  .card-layout {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background-color: oklch(0.44 0.14 240 / 0.10);
    border-radius: var(--radius-md);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .card-title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
    line-height: var(--leading-tight);
  }

  .card-summary {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    flex-grow: 1;
    padding-bottom: 1rem;
  }

  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: auto;
  }

  /* ── Hero layout (single project) ────────── */
  .hero-layout {
    display: grid;
    grid-template-columns: 1fr 18rem;
    gap: 3rem;
    align-items: center;
    height: 100%;
  }

  .card-main {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .hero-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
    line-height: var(--leading-tight);
  }

  .hero-summary {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 56ch;
    flex-grow: 1;
  }

  .hero-aside {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    justify-content: center;
    align-self: center;
  }

  .hero-cta {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.01em;
  }

  @media (max-width: 900px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .hero-aside {
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
    }
  }
</style>

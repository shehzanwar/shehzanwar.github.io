---
// src/pages/work/index.astro
import PageLayout from '../../layouts/PageLayout.astro';
import BentoGrid from '../../components/sections/BentoGrid.astro';
import BentoCard from '../../components/primitives/BentoCard.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { buildMeta } from '../../lib/seo';

const meta = buildMeta({
  title: 'Work — Shehzan Warraich',
  description:
    'A collection of forecasting models, data pipelines, and analytics tools — from OMSA capstone research to production systems.',
});

const allProjects = await getCollection('projects');

// Featured first (by order), then non-featured by publishedAt
const projects = allProjects.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  if (a.data.featured && b.data.featured) return a.data.order - b.data.order;
  return b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
});

const statusLabel: Record<string, string> = {
  shipped: 'Shipped',
  'in-progress': 'In progress',
  archived: 'Archived',
};
---

<PageLayout meta={meta}>
  <div class="page-section">
    <header class="page-header">
      <h1 class="page-title">Work</h1>
      <p class="page-desc">
        Forecasting models, analytics infrastructure, and the tooling built
        around them. Each project starts with a real decision someone needs to make.
      </p>
    </header>

    <BentoGrid>
      {projects.map(project => (
        <BentoCard
          href={`/work/${project.data.slug}`}
          colSpan={6}
          rowSpan={1}
          label={project.data.title}
        >
          <div class="card-row">
            {project.data.coverIcon && (
              <span class="card-icon">
                <Icon name={project.data.coverIcon} size={18} />
              </span>
            )}
            <span class={`status-badge status-badge--${project.data.status}`}>
              {statusLabel[project.data.status] ?? project.data.status}
            </span>
            {project.data.featured && (
              <span class="featured-badge">Featured</span>
            )}
          </div>

          <h2 class="card-title">{project.data.title}</h2>
          <p class="card-summary">{project.data.summary}</p>

          <div class="card-footer">
            <div class="card-stack">
              {project.data.stack.slice(0, 4).map(s => (
                <span class="chip">{s}</span>
              ))}
              {project.data.stack.length > 4 && (
                <span class="chip">+{project.data.stack.length - 4}</span>
              )}
            </div>
            <time class="card-date">
              {project.data.publishedAt.getFullYear()}
            </time>
          </div>
        </BentoCard>
      ))}
    </BentoGrid>
  </div>
</PageLayout>

<style>
  .page-header {
    max-width: 56ch;
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: 1rem;
  }

  .page-desc {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .card-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: var(--radius-md);
    background-color: oklch(0.44 0.14 240 / 0.10);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .featured-badge {
    margin-left: auto;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .card-title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
    line-height: var(--leading-tight);
  }

  .card-summary {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    flex-grow: 1;
    margin-bottom: 1.25rem;
  }

  .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    flex-wrap: wrap;
  }

  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .card-date {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>

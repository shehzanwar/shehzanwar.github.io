---
// src/pages/about.astro
import PageLayout from '../layouts/PageLayout.astro';
import ExperienceList from '../components/sections/ExperienceList.astro';
import SkillsGrid from '../components/sections/SkillsGrid.astro';
import { getCollection } from 'astro:content';
import { buildMeta } from '../lib/seo';

const meta = buildMeta({
  title: 'About — Shehzad Anwar',
  description:
    'Data scientist and software developer based in San Francisco. MS Analytics candidate at Georgia Tech, specializing in statistical learning, machine learning, and data engineering.',
});

const [experienceEntries, skillEntries] = await Promise.all([
  getCollection('experience'),
  getCollection('skills'),
]);

const experience = experienceEntries
  .sort((a, b) => b.data.start.getTime() - a.data.start.getTime());

const skills = skillEntries
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<PageLayout meta={meta}>
  <div class="page-section">
    <!-- Intro -->
    <section class="about-intro" aria-labelledby="about-heading">
      <h1 id="about-heading" class="about-heading">About</h1>
      <p class="about-lead">
        I'm a data scientist and software developer based in San Francisco,
        pursuing a Master of Science in Analytics at Georgia Tech (expected 2027).
        I graduated cum laude from Arizona State University with a BS in Computer
        Science, and I work at the intersection of statistical learning, data
        engineering, and predictive modeling.
      </p>
      <p class="about-body">
        I interned as a Data Analyst at Trinamix Inc., where I audited enterprise
        data integrity and used SQL to identify and remediate security
        vulnerabilities. As a freelance developer at Yanbor LLC., I led technical
        redesigns and engineered Python data processing tools that cut processing
        times by 27%. My graduate coursework at Georgia Tech — Computational Data
        Analysis (ISYE 6740) and Data Mining &amp; Statistical Learning (ISYE 7406)
        — drives my applied work in classification, regression, and sports
        analytics, including F1 lap-time prediction and Premier League match
        forecasting.
      </p>
    </section>

    <!-- Experience -->
    <section class="about-section" aria-labelledby="experience-heading">
      <h2 id="experience-heading" class="section-title" style="margin-bottom: 2rem;">
        Experience
      </h2>
      <ExperienceList entries={experience} />
    </section>

    <!-- Skills -->
    <section class="about-section" aria-labelledby="skills-heading">
      <h2 id="skills-heading" class="section-title" style="margin-bottom: 1.5rem;">
        Skills
      </h2>
      <SkillsGrid skills={skills} />
    </section>
  </div>
</PageLayout>

<style>
  .about-intro {
    max-width: 68ch;
    margin-bottom: 5rem;
  }

  .about-heading {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: 1.5rem;
  }

  .about-lead {
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .about-body {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-tertiary);
  }

  .about-section {
    margin-bottom: 5rem;
  }

  .about-section:last-child {
    margin-bottom: 0;
  }
</style>

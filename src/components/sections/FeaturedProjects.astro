---
// src/components/sections/FeaturedProjects.astro
import type { CollectionEntry } from 'astro:content';
import BentoGrid from './BentoGrid.astro';
import BentoCard from '../primitives/BentoCard.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;

const sorted = [...projects].sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  if (a.data.featured && b.data.featured) return a.data.order - b.data.order;
  return b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
});

const total = sorted.length;

const spanMap =
  total === 1 ? [{ col: 12, row: 2 }] :
  total === 2 ? [{ col: 6, row: 2 }, { col: 6, row: 2 }] :
                [{ col: 8, row: 2 }, { col: 4, row: 2 }, { col: 4, row: 1 }];

const statusLabel: Record<string, string> = {
  shipped:     'Shipped',
  'in-progress': 'In progress',
  archived:    'Archived',
};
---

<section>
  <div class="page-section" style="padding-top: 2rem;">
    <header class="section-header">
      <h2 class="section-title">Featured Work</h2>
      <a href="/projects" class="section-link">View all projects →</a>
    </header>

    <BentoGrid>
      {sorted.map((project, i) => {
        const { col, row } = spanMap[i] ?? { col: 4, row: 1 };
        const isHero = total === 1;
        const detailHref = `/projects/${project.data.slug}`;
        return (
          <BentoCard colSpan={col} rowSpan={row} label={project.data.title}>
            <div class={isHero ? 'hero-layout' : 'card-layout'}>
              <div class="card-main">
                <!-- Top: icon + badge -->
                <div class="card-top">
                  {project.data.coverIcon && (
                    <span class="card-icon" style={isHero ? 'width:2.75rem;height:2.75rem;' : ''}>
                      <Icon name={project.data.coverIcon} size={isHero ? 26 : 20} />
                    </span>
                  )}
                  <span class={`status-badge status-badge--${project.data.status}`}>
                    {statusLabel[project.data.status] ?? project.data.status}
                  </span>
                </div>

                <!-- Title -->
                <h3 class={isHero ? 'hero-title' : 'card-title'}>
                  <a href={detailHref} class="card-title-link">{project.data.title}</a>
                </h3>

                <!-- Summary -->
                <p class={isHero ? 'hero-summary' : 'card-summary'}>{project.data.summary}</p>

                <!-- Stack + footer (non-hero) -->
                {!isHero && (
                  <>
                    <div class="card-stack">
                      {project.data.stack.slice(0, 4).map(s => (
                        <span class="chip">{s}</span>
                      ))}
                      {project.data.stack.length > 4 && (
                        <span class="chip">+{project.data.stack.length - 4}</span>
                      )}
                    </div>
                    <div class="card-footer">
                      <a href={detailHref} class="card-detail-link">View project →</a>
                      {project.data.repoUrl && (
                        <a
                          href={project.data.repoUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="card-source-link"
                        >
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                          </svg>
                          View Source
                        </a>
                      )}
                    </div>
                  </>
                )}
              </div>

              <!-- Hero aside (single project layout) -->
              {isHero && (
                <div class="hero-aside">
                  <div class="card-stack">
                    {project.data.stack.map(s => (
                      <span class="chip">{s}</span>
                    ))}
                  </div>
                  {project.data.repoUrl ? (
                    <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" class="hero-cta">
                      View on GitHub →
                    </a>
                  ) : (
                    <a href={detailHref} class="hero-cta">View project →</a>
                  )}
                </div>
              )}
            </div>
          </BentoCard>
        );
      })}
    </BentoGrid>
  </div>
</section>

<style>
  /* ── Card internals ──────────────────────────────────────── */
  .card-layout {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-main {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.875rem;
  }

  .card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background-color: rgba(192, 193, 255, 0.08);
    border-radius: var(--radius-sm);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .card-title {
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
    line-height: 1.35;
  }

  .card-title-link {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .card-title-link:hover { color: var(--color-accent); }

  .card-summary {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: var(--leading-relaxed);
    flex-grow: 1;
    margin-bottom: 0.875rem;
  }

  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: auto;
    margin-bottom: 0.875rem;
  }

  .card-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin-top: auto;
  }

  .card-detail-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .card-detail-link:hover { color: var(--color-accent-hover); }

  .card-source-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-tertiary);
    text-decoration: none;
    margin-left: auto;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .card-source-link:hover { color: var(--color-text-primary); }

  /* ── Hero layout (single project mode) ─────────────────── */
  .hero-layout {
    display: grid;
    grid-template-columns: 1fr 18rem;
    gap: 3rem;
    align-items: center;
    height: 100%;
  }

  .hero-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
    line-height: var(--leading-tight);
  }

  .hero-summary {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 56ch;
    flex-grow: 1;
  }

  .hero-aside {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    justify-content: center;
    align-self: center;
  }

  .hero-cta {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .hero-cta:hover { color: var(--color-accent-hover); }

  @media (max-width: 900px) {
    .hero-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .hero-aside {
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
    }
  }
</style>

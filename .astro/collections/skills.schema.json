{
  "$ref": "#/definitions/skills",
  "definitions": {
    "skills": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "proficiencyLevel": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          },
          "minItems": 1,
          "maxItems": 10
        },
        "iconRef": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9-]*(:[a-z0-9][a-z0-9-]*)?$",
          "errorMessage": {
            "pattern": "iconRef must be a valid astro-icon ref (e.g. lucide:code)"
          }
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "proficiencyLevel",
        "tags",
        "iconRef"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
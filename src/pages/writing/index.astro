---
// src/pages/writing/index.astro
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { buildMeta } from '../../lib/seo';
import { formatDate } from '../../lib/format';

const meta = buildMeta({
  title: 'Writing — Shehzad Anwar',
  description:
    'Essays on Bayesian inference, reproducible analytics, data tooling, and the craft of working with messy data.',
});

const writing = (await getCollection('writing'))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<PageLayout meta={meta}>
  <div class="page-section">
    <header class="page-header">
      <h1 class="page-title">Writing</h1>
      <p class="page-desc">
        Occasional essays on Bayesian inference, reproducible analytics,
        data tooling, and the craft of working with messy data.
      </p>
    </header>

    <ol class="article-list" role="list">
      {writing.map(post => (
        <li>
          <a href={`/writing/${post.data.slug}`} class="article-card">
            <div class="article-meta">
              <time datetime={post.data.publishedAt.toISOString()}>
                {formatDate(post.data.publishedAt)}
              </time>
              <span aria-hidden="true">·</span>
              <span>{post.data.readingTime} min read</span>
            </div>

            <h2 class="article-title">{post.data.title}</h2>
            <p class="article-excerpt">{post.data.excerpt}</p>

            <div class="article-tags">
              {post.data.tags.map(t => <span class="tag">{t}</span>)}
            </div>
          </a>
        </li>
      ))}
    </ol>
  </div>
</PageLayout>

<style>
  .page-header {
    max-width: 52ch;
    margin-bottom: 3.5rem;
  }

  .page-title {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin-bottom: 1rem;
  }

  .page-desc {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .article-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: padding-left var(--duration-base) var(--ease-out-expo);
  }

  .article-list li:last-child .article-card {
    border-bottom: 1px solid var(--color-border);
  }

  .article-card:hover { padding-left: 0.75rem; }

  .article-card:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin-bottom: 0.625rem;
  }

  .article-title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    line-height: var(--leading-tight);
    margin-bottom: 0.5rem;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }

  .article-card:hover .article-title { color: var(--color-accent); }

  .article-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 72ch;
    margin-bottom: 1rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .article-card { transition: none; }
    .article-card:hover { padding-left: 0; }
    .article-title { transition: none; }
  }
</style>

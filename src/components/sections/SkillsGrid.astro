---
// src/components/sections/SkillsGrid.astro
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';

interface Props {
  skills: CollectionEntry<'skills'>[];
}

const { skills } = Astro.props;

const CATEGORIES = ['Languages', 'Libraries & Frameworks', 'Developer Tools'] as const;

const grouped = Object.fromEntries(
  CATEGORIES.map(cat => [cat, skills.filter(s => s.data.category === cat)])
);
---

<div class="skills-categories">
  {CATEGORIES.filter(cat => grouped[cat].length > 0).map(cat => (
    <div class="skill-group">
      <h3 class="group-label">{cat}</h3>
      <ul class="skill-list" role="list">
        {grouped[cat].map(skill => (
          <li class="skill-chip">
            <span class="skill-icon" aria-hidden="true">
              <Icon name={skill.data.iconRef} size={14} />
            </span>
            <span class="skill-name">{skill.data.title}</span>
            {skill.data.tags.slice(0, 3).map(tag => (
              <span class="skill-tag">{tag}</span>
            ))}
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>

<style>
  .skills-categories {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .skill-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .group-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-tertiary);
    margin: 0;
  }

  .skill-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .skill-chip {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .skill-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: var(--radius-sm);
    background-color: oklch(0.44 0.14 240 / 0.10);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .skill-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-right: 0.125rem;
  }

  .skill-tag {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    background-color: var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.125rem 0.5rem;
    line-height: 1.6;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .skills-categories { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 560px) {
    .skills-categories { grid-template-columns: 1fr; }
  }
</style>

---
// src/components/sections/RecentWriting.astro
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../../lib/format';

interface Props {
  writing: CollectionEntry<'writing'>[];
}

const { writing } = Astro.props;
---

<section>
  <div class="page-section" style="padding-top: 0;">
    <header class="section-header">
      <h2 class="section-title">Writing</h2>
      <a href="/writing" class="section-link">All articles →</a>
    </header>

    <ul class="writing-list" role="list">
      {writing.map(post => (
        <li>
          <a href={`/writing/${post.data.slug}`} class="writing-card">
            <div class="writing-meta">
              <time datetime={post.data.publishedAt.toISOString()}>
                {formatDate(post.data.publishedAt)}
              </time>
              <span class="meta-sep" aria-hidden="true">·</span>
              <span>{post.data.readingTime} min read</span>
            </div>

            <h3 class="writing-title">{post.data.title}</h3>
            <p class="writing-excerpt">{post.data.excerpt}</p>

            <div class="writing-tags">
              {post.data.tags.slice(0, 3).map(t => (
                <span class="tag">{t}</span>
              ))}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .writing-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .writing-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-card);
    transition:
      transform     var(--duration-base) var(--ease-out-expo),
      border-color  var(--duration-base) var(--ease-out-expo),
      box-shadow    var(--duration-base) var(--ease-out-expo);
    will-change: transform;
  }

  .writing-card:hover {
    transform: translate3d(0, -3px, 0);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
  }

  .writing-card:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .writing-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin-bottom: 0.75rem;
  }

  .meta-sep { opacity: 0.5; }

  .writing-title {
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    line-height: var(--leading-tight);
    margin-bottom: 0.5rem;
  }

  .writing-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    flex-grow: 1;
    margin-bottom: 1rem;
  }

  .writing-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .writing-card { will-change: auto; }
    .writing-card:hover { transform: none; opacity: 0.85; }
  }

  @media (max-width: 900px) {
    .writing-list { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 580px) {
    .writing-list { grid-template-columns: 1fr; }
  }
</style>

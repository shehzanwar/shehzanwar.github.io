---
// src/components/sections/Hero.astro
// M06 BOUNDARY: canvas inside clip-path skewed wrapper, aria-hidden.
// H1 uses background-clip: text. No parallax effects.
import MeshGradient from '../islands/MeshGradient';
---

<section class="hero" aria-labelledby="hero-headline">
  <!-- Skewed gradient background — canvas inside clip-path wrapper -->
  <div class="hero-gradient" aria-hidden="true">
    <MeshGradient client:load />
  </div>

  <div class="hero-content">
    <!-- Left: headline + subhead + CTAs -->
    <div class="hero-left">
      <p class="hero-eyebrow">Machine Learning &amp; Data Analyst</p>

      <h1 id="hero-headline" class="hero-headline">
        Shehzad<br />Anwar
      </h1>

      <p class="hero-subhead">
        Building predictive models, data processing pipelines, and software
        applications. Currently pursuing an MS in Analytics at Georgia Tech.
      </p>

      <div class="hero-ctas">
        <a href="/projects" class="cta-primary">View Projects</a>
        <a
          href="/SA_Resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 rounded-full font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors"
        >View Resume</a>
        <a href="/about" class="cta-secondary">About Me</a>
      </div>
    </div>

    <!-- Right: terminal-style OMSA project snippet (decorative) -->
    <div class="hero-right" aria-hidden="true">
      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot dot-red"></span>
          <span class="terminal-dot dot-yellow"></span>
          <span class="terminal-dot dot-green"></span>
          <span class="terminal-filename">f1_lap_prediction.py</span>
        </div>
        <pre
          class="terminal-body"
        ><code>&gt;&gt;&gt; import fastf1
&gt;&gt;&gt; from sklearn.ensemble import RandomForestRegressor
&gt;&gt;&gt; from sklearn.decomposition import PCA
&gt;&gt;&gt;
&gt;&gt;&gt; session = fastf1.get_session(<span class="t-num">2023</span>, <span class="t-str">'Silverstone'</span>, <span class="t-str">'Q'</span>)
&gt;&gt;&gt; session.load(telemetry=<span class="t-num">True</span>)
&gt;&gt;&gt;
&gt;&gt;&gt; X = session.telemetry[[<span class="t-str">'Speed'</span>, <span class="t-str">'Brake'</span>, <span class="t-str">'Throttle'</span>, <span class="t-str">'DRS'</span>]]
&gt;&gt;&gt; y = session.telemetry[<span class="t-str">'Time'</span>]
&gt;&gt;&gt;
&gt;&gt;&gt; pca = PCA(n_components=<span class="t-num">2</span>)  <span class="t-comment"># reduce telemetry noise</span>
&gt;&gt;&gt; X_reduced = pca.fit_transform(X)
&gt;&gt;&gt;
&gt;&gt;&gt; model = RandomForestRegressor(n_estimators=<span class="t-num">100</span>)
&gt;&gt;&gt; model.fit(X_reduced, y)
<span class="t-output">RandomForestRegressor(n_estimators=100)</span></code></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Skewed gradient wrapper — clip-path cuts the bottom edge diagonally */
  .hero-gradient {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    clip-path: polygon(0 0, 100% 0, 100% 84%, 0 100%);
    z-index: -1;
    overflow: hidden;
  }

  /* Content sits above the gradient */
  .hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 7rem 1.5rem 9rem;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 5rem;
    align-items: center;
  }

  /* ── Left column ───────────────────────────── */
  .hero-eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1rem;
  }

  .hero-headline {
    font-size: clamp(2.75rem, 6vw, var(--text-7xl));
    font-weight: 700;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    text-shadow: 0 1px 12px rgb(0 0 0 / 18%), 0 0 40px rgb(0 0 0 / 10%);
    margin: 0 0 1.5rem;
  }

  .hero-subhead {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    max-width: 44ch;
    margin: 0 0 2.5rem;
  }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.375rem;
    background-color: var(--color-accent);
    color: oklch(0.98 0.005 90);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-out-expo),
      transform         var(--duration-fast) var(--ease-out-expo);
  }

  .cta-primary:hover {
    background-color: var(--color-accent-hover);
    transform: translate3d(0, -1px, 0);
  }

  .cta-primary:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 3px;
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.375rem;
    border: 1px solid var(--color-border-strong);
    color: var(--color-text-primary);
    font-size: var(--text-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    text-decoration: none;
    background: transparent;
    transition:
      border-color var(--duration-fast) var(--ease-out-expo),
      color        var(--duration-fast) var(--ease-out-expo),
      transform    var(--duration-fast) var(--ease-out-expo);
  }

  .cta-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translate3d(0, -1px, 0);
  }

  .cta-secondary:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 3px;
  }

  /* ── Terminal block ────────────────────────── */
  .terminal {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.625rem 0.875rem;
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-surface-elevated);
  }

  .terminal-dot {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green  { background: #28c840; }

  .terminal-filename {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    margin-left: 0.5rem;
  }

  .terminal-body {
    margin: 0;
    padding: 1.25rem 1.375rem 1.5rem;
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    line-height: 1.85;
    color: var(--color-text-secondary);
    overflow-x: auto;
    white-space: pre;
  }

  .terminal-body code { font-family: inherit; }

  .t-str     { color: var(--color-success); }
  .t-num     { color: var(--color-warning); }
  .t-comment { color: var(--color-text-tertiary); }
  .t-output  {
    color: var(--color-accent);
    font-weight: 600;
    display: block;
  }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 960px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding-bottom: 7rem;
    }

    .hero-right {
      max-width: 520px;
    }
  }

  @media (max-width: 480px) {
    .hero-right {
      display: none;
    }
  }
</style>
